<Application
    x:Class="Kil0bitSystemMonitor.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    xmlns:local="clr-namespace:Kil0bitSystemMonitor"
    xmlns:helpers="clr-namespace:Kil0bitSystemMonitor.Helpers">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
            <helpers:StringFormatConverter x:Key="StringFormatConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
